@model PrintShop.Models.PrintOrder
@{
    ViewData["Title"] = "Pedido Confirmado";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="success-page">
    <div class="success-icon">✓</div>
    <h1>Pedido confirmado!</h1>
    <p class="success-subtitle">Seu pedido <strong>#@Model.Id</strong> foi recebido e está sendo processado.</p>

    <div class="status-tracker">
        <div class="status-step @(Model.Status >= PrintShop.Models.OrderStatus.PaymentConfirmed ? "done" : "") active">
            <div class="step-circle">💳</div>
            <span>Pagamento</span>
        </div>
        <div class="step-line"></div>
        <div class="status-step @(Model.Status == PrintShop.Models.OrderStatus.Printing || Model.Status == PrintShop.Models.OrderStatus.Ready ? "done" : "")" id="printStep">
            <div class="step-circle">🖨️</div>
            <span>Imprimindo</span>
        </div>
        <div class="step-line"></div>
        <div class="status-step @(Model.Status == PrintShop.Models.OrderStatus.Ready ? "done" : "")" id="readyStep">
            <div class="step-circle">✅</div>
            <span>Pronto</span>
        </div>
    </div>

    <div class="status-message" id="statusMsg">
        <div class="spinner"></div>
        <span id="statusText">@GetStatusLabel(Model.Status)</span>
    </div>

    <div class="success-info">
        <div class="info-row">
            <span>Método de pagamento</span>
            <strong>@(Model.PaymentMethod == PrintShop.Models.PaymentMethod.Pix ? "PIX" : "Pagamento na loja")</strong>
        </div>
        <div class="info-row">
            <span>Valor pago</span>
            <strong>R$ @Model.TotalPrice.ToString("F2")</strong>
        </div>
        <div class="info-row">
            <span>Cliente</span>
            <strong>@Model.CustomerName</strong>
        </div>
    </div>

    <a href="/" class="btn-ghost">Fazer outro pedido</a>
</div>

@section Scripts {
<script>
const orderId = '@Model.Id';
const interval = setInterval(async () => {
    const res = await fetch(`/Order/Status/${orderId}`);
    const data = await res.json();
    document.getElementById('statusText').textContent = data.statusLabel;

    if (data.status === 'Printing') {
        document.getElementById('printStep').classList.add('done', 'active');
    }
    if (data.status === 'Ready') {
        document.getElementById('printStep').classList.add('done');
        document.getElementById('readyStep').classList.add('done', 'active');
        document.getElementById('statusMsg').innerHTML =
            `<div class="ready-badge">🎉 Seu pedido está pronto para retirada!</div>`;
        clearInterval(interval);
    }
    if (data.status === 'Cancelled') clearInterval(interval);
}, 4000);
</script>
}

@functions {
    string GetStatusLabel(PrintShop.Models.OrderStatus status) => status switch {
        PrintShop.Models.OrderStatus.PendingPayment => "Aguardando pagamento",
        PrintShop.Models.OrderStatus.PaymentConfirmed => "Pagamento confirmado",
        PrintShop.Models.OrderStatus.Printing => "Imprimindo seus arquivos...",
        PrintShop.Models.OrderStatus.Ready => "Pronto para retirada!",
        _ => status.ToString()
    };
}
