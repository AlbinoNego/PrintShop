@{
    ViewData["Title"] = "Início";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="hero">
    <div class="hero-text">
        <span class="hero-tag">Impressão Online</span>
        <h1>Imprima sem<br/><em>sair de casa.</em></h1>
        <p>Envie seus arquivos, escolha as opções e pague online. Sua impressão fica pronta na papelaria.</p>
        <a href="/Order/New" class="btn-primary">Fazer Pedido →</a>
    </div>
    <div class="hero-visual">
        <div class="float-card card-1">
            <span class="card-icon">📄</span>
            <div>
                <strong>PDF, Word, PPT</strong>
                <small>e imagens</small>
            </div>
        </div>
        <div class="float-card card-2">
            <span class="card-icon">🖨️</span>
            <div>
                <strong>Impressão automática</strong>
                <small>após pagamento</small>
            </div>
        </div>
        <div class="float-card card-3">
            <span class="card-icon">⚡</span>
            <div>
                <strong>Pix ou na loja</strong>
                <small>você escolhe</small>
            </div>
        </div>
    </div>
</div>

<section class="steps">
    <h2>Como funciona</h2>
    <div class="steps-grid">
        <div class="step">
            <div class="step-num">01</div>
            <h3>Envie os arquivos</h3>
            <p>PDF, Word, PowerPoint ou imagens — até 50MB por arquivo.</p>
        </div>
        <div class="step">
            <div class="step-num">02</div>
            <h3>Configure a impressão</h3>
            <p>Cor, cópias, tipo de papel, frente e verso, plastificação.</p>
        </div>
        <div class="step">
            <div class="step-num">03</div>
            <h3>Pague online</h3>
            <p>Via Pix ou diretamente na loja na hora da retirada.</p>
        </div>
        <div class="step">
            <div class="step-num">04</div>
            <h3>Retire pronto</h3>
            <p>A impressão começa automaticamente. Você recebe o aviso.</p>
        </div>
    </div>
</section>
